                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
                <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="#444444" android:layout_margin="1dp"/>
